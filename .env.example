# Jenkins 地址，例如 http://jenkins.example.com
JENKINS_BASE_URL=

# Jenkins 用户名
JENKINS_USER=

# Jenkins API Token，不是登录密码
JENKINS_TOKEN=

# 钉钉应用信息。当前主流程通过 OpenClaw 进来，一般不需要本项目直接读取这些字段。
DINGTALK_APP_ID=
DINGTALK_AGENT_ID=
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
DINGTALK_ROBOT_CODE=

# Teambition OpenAPI 地址，一般保持默认
TEAMBITION_BASE_URL=https://open.teambition.com/api

# Teambition 应用凭证
TEAMBITION_APP_ID=
TEAMBITION_APP_SECRET=

# Teambition 组织 ID。使用同一个项目时，通常可以保持为空，让 configs/teambition_bug_form.v1.yaml 提供默认值。
TEAMBITION_ORG_ID=

# Teambition 操作人 ID。需要是有权限创建任务/缺陷的成员 ID。
TEAMBITION_OPERATOR_ID=

# 下面两个字段通常可以保持为空。
# 为空时会使用 configs/teambition.yaml 和 configs/teambition_bug_form.v1.yaml 里的默认 ID。
# 只有换 Teambition 项目或任务列表时才需要填写覆盖。
TEAMBITION_PROJECT_ID=
TEAMBITION_TASKLIST_ID=

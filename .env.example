# Jenkins 必填
JENKINS_BASE_URL=
JENKINS_USER=
JENKINS_TOKEN=

# 钉钉字段当前一般不填，由 OpenClaw 或 Hermes Gateway 负责接入钉钉
# 如果使用 Hermes Gateway，请把这些值填到 `hermes config env-path` 指向的 Hermes .env
DINGTALK_APP_ID=
DINGTALK_AGENT_ID=
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
DINGTALK_ROBOT_CODE=

# Teambition 必填
TEAMBITION_BASE_URL=https://open.teambition.com/api
TEAMBITION_APP_ID=
TEAMBITION_APP_SECRET=
TEAMBITION_OPERATOR_ID=

# 同一个 Teambition 项目通常不用填，默认读 configs/ 里的 ID
TEAMBITION_ORG_ID=
TEAMBITION_PROJECT_ID=
TEAMBITION_TASKLIST_ID=
